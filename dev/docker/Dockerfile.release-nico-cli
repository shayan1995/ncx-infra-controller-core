ARG CONTAINER_BUILD

FROM $CONTAINER_BUILD as builder
ARG VERSION
ENV VERSION $VERSION
ENV CONTAINER_REPO_ROOT=/nico
#RUN USER=root cargo new --bin nico
RUN mkdir /nico
WORKDIR ./nico
COPY . ./

# --mount=type=cache persists the sccache directory across builds. Requires BuildKit (default in Docker 23+).
RUN --mount=type=cache,id=sccache-x86_64,target=/sccache \
  cd /nico && \
  export SCCACHE_DIR=/sccache && \
  export RUSTC_WRAPPER=sccache && \
  export CARGO_PROFILE_RELEASE_DEBUG=true && \
  cargo build --release -p nico-admin-cli

FROM debian:12-slim
ARG CI_COMMIT_SHORT_SHA
ENV CI_COMMIT_SHORT_SHA $CI_COMMIT_SHORT_SHA

RUN apt update && \
    apt install -y \
    jq \
    libtss2-dev

WORKDIR /app
COPY --from=builder /nico/target/release/nico-admin-cli ./
# Cert paths read by nico-admin-cli via nico_api_cli.json.
# Internal deployments: mount provisioned client certs into /root/.config/nico/certs/.
RUN mkdir -p /root/.config/nico/certs && \
mkdir -p /opt/nico
COPY ./dev/certs/nico_root.pem /opt/nico
RUN echo '{"nico_root_ca_path": "/opt/nico/nico_root.pem","client_key_path": "/root/.config/nico/certs/client","client_cert_path": "/root/.config/nico/certs/client.crt"}' > /root/.config/nico_api_cli.json
ENV PATH="$PATH:/app"

ENTRYPOINT ["/app/nico-admin-cli"]
