# This should match rust-toolchain.toml
ARG CONTAINER_BUILD_AARCH64
ARG CONTAINER_RUNTIME_AARCH64

FROM $CONTAINER_BUILD_AARCH64 as builder
ARG CI_COMMIT_SHORT_SHA
ENV CI_COMMIT_SHORT_SHA $CI_COMMIT_SHORT_SHA

ARG VERSION
ENV VERSION $VERSION
ENV CONTAINER_REPO_ROOT=/nico

RUN USER=root cargo new --bin nico
WORKDIR ./nico
COPY . ./

# --mount=type=cache persists the sccache directory across docker build invocations.
# Uses id=sccache-aarch64 (separate from x86_64 cache) since compiled artifacts are arch-specific.
# Requires BuildKit (default in Docker 23+).
RUN --mount=type=cache,id=sccache-aarch64,target=/sccache \
  export CARGO_MAKE_SKIP_CODECOV="true" && \
  export DATABASE_URL="postgresql://%2Fvar%2Frun%2Fpostgresql" && \
  export SCCACHE_DIR=/sccache && \
  export RUSTC_WRAPPER=sccache && \
  export CARGO_PROFILE_RELEASE_DEBUG=true && \
  /etc/init.d/postgresql start && \
  sudo -u postgres psql -c "ALTER USER root WITH SUPERUSER;" && \
  createdb root && \
  cargo make build-and-test-release-container-services && \
  echo "$(date): Finished cargo make build-and-test-release-container-services\n" && \
  mkdir -p /nico/target/bin && \
  find /nico/target/release -maxdepth 1 -type f -exec cp -t /nico/target/bin {} + && \
  rm -rf /nico/target/debug && \
  rm -rf /nico/target/release && \
  echo "$(date): Deleted artifacts"

# After build, copy the release into the runtime container
FROM $CONTAINER_RUNTIME_AARCH64
RUN mkdir -p /opt/nico/migrations && \
  mkdir -p /opt/nico/pxe/templates && \
  mkdir -p /opt/nico/static

RUN echo "$(date): Start runtime container build"

COPY --from=builder ["/nico/target/bin/nico-api", "/nico/target/bin/nico", "/nico/target/bin/nico-dns", "/nico/target/bin/nico-admin-cli", "/nico/target/bin/nico-dsx-exchange-consumer", "/nico/target/bin/nico-dpu-agent", "/nico/target/bin/nico-dhcp-server", "/nico/target/bin/nico-hw-health", "/nico/target/bin/nico-log-parser", "/nico/target/bin/ssh-console", "/nico/target/bin/nico-bmc-proxy", "/opt/nico/"]
# Note: aarch64 uses different library path than x86_64
COPY --from=builder /nico/target/bin/libdhcp.so /usr/lib/aarch64-linux-gnu/kea/hooks
RUN ln -s /opt/nico/nico-admin-cli /opt/nico/nico-admin-cli

RUN echo "$(date): Finished copies"

COPY crates/api-db/migrations/ /opt/nico/migrations/
COPY pxe/templates/*  /opt/nico/pxe/templates/
COPY crates/api/casbin-policy.csv /opt/nico/

ENV CASBIN_POLICY_FILE=/opt/nico/casbin-policy.csv

